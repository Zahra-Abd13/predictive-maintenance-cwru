# ── Data files ────────────────────────────────────────────
# Raw .mat files are too large for GitHub (download from CWRU site)
data/raw/*.mat
data/raw/*.MAT

# Processed numpy arrays (regenerated by running notebooks)
data/processed/*.npy
data/processed/*.csv

# Keep the data folder structure
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/validation/.gitkeep

# ── Model files ───────────────────────────────────────────
# Large model .pkl files — keep only the inference pipeline
models/logistic_regression.pkl
models/random_forest.pkl
models/random_forest_tuned.pkl
models/xgboost.pkl
models/rf_selected_features.pkl
models/feature_selector.pkl

# Keep the essential deployment files
!models/inference_pipeline.pkl
!models/scaler.pkl
!models/model_results.csv
!models/decision_log.csv
!models/model_size_comparison.csv

